{
  "name": "@transform-ia/ra-kit",
  "version": "0.1.0",
  "description": "Reusable React Admin components for TransformIA projects",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@mui/icons-material": ">=5",
    "@mui/material": ">=5",
    "react": ">=18",
    "react-admin": ">=5"
  },
  "devDependencies": {
    "@mui/icons-material": "^7.0.0",
    "@mui/material": "^7.0.0",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "react-admin": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "~5.9.0"
  }
}
